# ── Backend (Netlify Functions) ─────────────────────────────────────────────
# Set these in Netlify: Site settings → Environment variables.
# NEVER commit real values or expose the service-role / key-secret to the frontend.

# Supabase → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Razorpay → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your-key-secret

# Razorpay → Subscriptions → Plans → create a monthly plan, copy its id
RAZORPAY_PLAN_ID=plan_xxxxxxxx

# Razorpay → Settings → Webhooks → the secret you choose when registering
# https://<your-site>/api/razorpay-webhook
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ── Frontend (Vite: must be prefixed VITE_, safe to expose) ─────────────────
# Same Supabase project; the anon key is public by design (RLS protects data).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
